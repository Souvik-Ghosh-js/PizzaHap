{
  "openapi": "3.0.3",
  "info": {
    "title": "PizzaHap API",
    "description": "Complete REST API for PizzaHap pizza ordering system.\n\n## Auth Flow\n1. `POST /auth/send-otp` → OTP sent to email\n2. `POST /auth/register` or `POST /auth/login` → receive `accessToken` + `refreshToken`\n3. Use `Authorization: Bearer <accessToken>` on all protected routes\n\n## Admin Auth\n- `POST /admin/auth/login` with email + password → admin JWT\n\n## Base URL\n`http://13.232.73.121/api`",
    "version": "2.0.0",
    "contact": { "name": "PizzaHap Support", "email": "support@pizzahap.com" }
  },
  "servers": [
    { "url": "http://13.232.73.121/api", "description": "Production" },
    { "url": "http://localhost:3000/api", "description": "Local Development" }
  ],
  "tags": [
    { "name": "Auth", "description": "Email OTP-based login and registration" },
    { "name": "Locations", "description": "Branch locations with nearest detection" },
    { "name": "Menu", "description": "Categories, products, toppings, crusts" },
    { "name": "Orders", "description": "Place, track, cancel, reorder" },
    { "name": "Payments", "description": "PayU + Cash on Delivery" },
    { "name": "Refunds", "description": "Request and track refunds" },
    { "name": "Coupons", "description": "List and validate discount codes" },
    { "name": "Ratings", "description": "Submit and view product ratings" },
    { "name": "Notifications", "description": "In-app notification inbox" },
    { "name": "Support", "description": "Customer support ticket system" },
    { "name": "Admin - Auth", "description": "Admin login" },
    { "name": "Admin - Dashboard", "description": "Stats and revenue reports" },
    { "name": "Admin - Orders", "description": "View and update order status" },
    { "name": "Admin - Users", "description": "Manage customers" },
    { "name": "Admin - Menu", "description": "Manage products and categories" },
    { "name": "Admin - Coupons", "description": "Create and manage coupons" },
    { "name": "Admin - Refunds", "description": "Process refund requests" },
    { "name": "Admin - Support", "description": "Handle support tickets" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT access token from /auth/login or /admin/auth/login"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string", "example": "Success" },
          "data": { "type": "object" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string", "example": "Something went wrong" },
          "errors": { "type": "array", "items": { "type": "object" } }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": { "type": "array", "items": {} },
          "pagination": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "page": { "type": "integer" },
              "limit": { "type": "integer" },
              "totalPages": { "type": "integer" }
            }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "mobile": { "type": "string", "nullable": true },
          "profile_picture": { "type": "string", "nullable": true },
          "address": { "type": "string", "nullable": true },
          "latitude": { "type": "number", "nullable": true },
          "longitude": { "type": "number", "nullable": true },
          "preferred_location_id": { "type": "integer", "nullable": true },
          "preferred_location_name": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "AuthTokens": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/User" },
          "accessToken": { "type": "string", "description": "JWT valid for 7 days" },
          "refreshToken": { "type": "string", "description": "JWT valid for 30 days" }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "address": { "type": "string" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "phone": { "type": "string", "nullable": true },
          "opening_time": { "type": "string", "nullable": true },
          "closing_time": { "type": "string", "nullable": true },
          "distance_km": { "type": "number", "nullable": true }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "image_url": { "type": "string", "nullable": true },
          "sort_order": { "type": "integer" }
        }
      },
      "ProductSize": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "size_name": { "type": "string", "example": "Medium" },
          "price": { "type": "number", "example": 299 },
          "is_available": { "type": "boolean" }
        }
      },
      "CrustType": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string", "example": "Thin Crust" },
          "extra_price": { "type": "number", "example": 0 },
          "is_available": { "type": "boolean" }
        }
      },
      "Topping": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string", "example": "Extra Cheese" },
          "price": { "type": "number", "example": 49 },
          "is_veg": { "type": "boolean" },
          "is_available": { "type": "boolean" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "image_url": { "type": "string", "nullable": true },
          "base_price": { "type": "number" },
          "category_id": { "type": "integer" },
          "category_name": { "type": "string" },
          "is_veg": { "type": "boolean" },
          "is_featured": { "type": "boolean" },
          "is_available": { "type": "boolean" },
          "avg_rating": { "type": "number", "nullable": true },
          "review_count": { "type": "integer", "nullable": true }
        }
      },
      "ProductDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/Product" },
          {
            "type": "object",
            "properties": {
              "sizes": { "type": "array", "items": { "$ref": "#/components/schemas/ProductSize" } },
              "crusts": { "type": "array", "items": { "$ref": "#/components/schemas/CrustType" } },
              "toppings": { "type": "array", "items": { "$ref": "#/components/schemas/Topping" } },
              "reviews": { "type": "array", "items": { "$ref": "#/components/schemas/Review" } }
            }
          }
        ]
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
          "review": { "type": "string", "nullable": true },
          "user_name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "product_id": { "type": "integer" },
          "size_id": { "type": "integer" },
          "crust_id": { "type": "integer", "nullable": true },
          "toppings": { "type": "array", "items": { "type": "integer" }, "description": "Topping IDs" },
          "quantity": { "type": "integer", "minimum": 1, "default": 1 },
          "special_instructions": { "type": "string", "nullable": true }
        },
        "required": ["product_id", "size_id"]
      },
      "OrderCalculation": {
        "type": "object",
        "properties": {
          "subtotal": { "type": "number" },
          "discount_amount": { "type": "number" },
          "delivery_fee": { "type": "number" },
          "tax_amount": { "type": "number" },
          "total_amount": { "type": "number" },
          "coupon": { "type": "object", "nullable": true }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "order_number": { "type": "string", "example": "GOBT-1234567" },
          "status": { "type": "string", "enum": ["pending","confirmed","preparing","out_for_delivery","delivered","cancelled"] },
          "payment_status": { "type": "string", "enum": ["pending","paid","failed","refunded"] },
          "delivery_type": { "type": "string", "enum": ["delivery","pickup"] },
          "delivery_address": { "type": "string", "nullable": true },
          "subtotal": { "type": "number" },
          "discount_amount": { "type": "number" },
          "delivery_fee": { "type": "number" },
          "tax_amount": { "type": "number" },
          "total_amount": { "type": "number" },
          "location_name": { "type": "string" },
          "special_instructions": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Coupon": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "example": "PIZZA20" },
          "description": { "type": "string", "nullable": true },
          "discount_type": { "type": "string", "enum": ["percentage","flat"] },
          "discount_value": { "type": "number" },
          "min_order_value": { "type": "number" },
          "valid_until": { "type": "string", "format": "date-time" }
        }
      },
      "SupportTicket": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "ticket_number": { "type": "string" },
          "subject": { "type": "string" },
          "category": { "type": "string", "enum": ["order_issue","payment","refund","delivery","other"] },
          "status": { "type": "string", "enum": ["open","in_progress","resolved","closed"] },
          "order_number": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "paths": {
    "/auth/send-otp": {
      "post": {
        "tags": ["Auth"],
        "summary": "Send OTP to email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": { "email": { "type": "string", "format": "email", "example": "user@example.com" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP sent", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/auth/resend-otp": {
      "post": {
        "tags": ["Auth"],
        "summary": "Resend OTP to email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": { "email": { "type": "string", "format": "email" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP resent" },
          "400": { "description": "Error" }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "otp"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "email": { "type": "string", "format": "email" },
                  "otp": { "type": "string", "minLength": 6, "maxLength": 6, "example": "123456" },
                  "mobile": { "type": "string", "pattern": "^[6-9]\\d{9}$", "description": "10-digit Indian mobile", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registered successfully",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/AuthTokens" } } }] } } }
          },
          "400": { "description": "Invalid OTP or validation error" },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login with email + OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "otp"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "otp": { "type": "string", "minLength": 6, "maxLength": 6 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/AuthTokens" } } }] } } }
          },
          "400": { "description": "Invalid OTP" },
          "401": { "description": "Account blocked or deactivated" },
          "404": { "description": "Email not registered" }
        }
      }
    },
    "/auth/refresh-token": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": { "refreshToken": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "New tokens issued" },
          "401": { "description": "Invalid or expired refresh token" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout (invalidate refresh token)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "refreshToken": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Logged out" } }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current user profile",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "User profile",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/User" } } }] } } }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/auth/profile": {
      "put": {
        "tags": ["Auth"],
        "summary": "Update user profile",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "mobile": { "type": "string", "pattern": "^[6-9]\\d{9}$" },
                  "address": { "type": "string" },
                  "latitude": { "type": "number" },
                  "longitude": { "type": "number" },
                  "preferred_location_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Profile updated" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/locations": {
      "get": {
        "tags": ["Locations"],
        "summary": "Get all branch locations",
        "parameters": [
          { "in": "query", "name": "latitude", "schema": { "type": "number" }, "description": "User latitude for distance calc" },
          { "in": "query", "name": "longitude", "schema": { "type": "number" }, "description": "User longitude for distance calc" }
        ],
        "responses": {
          "200": { "description": "List of locations sorted by distance if coords provided",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Location" } } } }] } } } }
        }
      }
    },
    "/locations/nearest": {
      "get": {
        "tags": ["Locations"],
        "summary": "Get nearest branch",
        "parameters": [
          { "in": "query", "name": "latitude", "schema": { "type": "number" } },
          { "in": "query", "name": "longitude", "schema": { "type": "number" } }
        ],
        "responses": { "200": { "description": "Nearest location" } }
      }
    },
    "/locations/{id}": {
      "get": {
        "tags": ["Locations"],
        "summary": "Get location by ID",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Location detail" }, "404": { "description": "Not found" } }
      }
    },
    "/menu/categories": {
      "get": {
        "tags": ["Menu"],
        "summary": "Get all categories",
        "responses": {
          "200": { "description": "Categories list",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } } } }] } } } }
        }
      }
    },
    "/menu/products": {
      "get": {
        "tags": ["Menu"],
        "summary": "Get products with filters and pagination",
        "parameters": [
          { "in": "query", "name": "category_id", "schema": { "type": "integer" }, "description": "Filter by category" },
          { "in": "query", "name": "is_veg", "schema": { "type": "boolean" }, "description": "Filter veg/non-veg" },
          { "in": "query", "name": "search", "schema": { "type": "string" }, "description": "Search by name or description" },
          { "in": "query", "name": "page", "schema": { "type": "integer", "default": 1 } },
          { "in": "query", "name": "limit", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "Paginated products",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } }
        }
      }
    },
    "/menu/products/featured": {
      "get": {
        "tags": ["Menu"],
        "summary": "Get featured products (top 10)",
        "responses": { "200": { "description": "Featured products list" } }
      }
    },
    "/menu/products/{id}": {
      "get": {
        "tags": ["Menu"],
        "summary": "Get product detail with sizes, crusts, toppings, reviews",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Full product detail",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/ProductDetail" } } }] } } } },
          "404": { "description": "Product not found" }
        }
      }
    },
    "/menu/toppings": {
      "get": {
        "tags": ["Menu"],
        "summary": "Get all available toppings",
        "parameters": [{ "in": "query", "name": "is_veg", "schema": { "type": "boolean" } }],
        "responses": { "200": { "description": "Toppings list" } }
      }
    },
    "/menu/crusts": {
      "get": {
        "tags": ["Menu"],
        "summary": "Get all crust types",
        "responses": { "200": { "description": "Crusts list" } }
      }
    },
    "/orders/calculate": {
      "post": {
        "tags": ["Orders"],
        "summary": "Calculate order total before placing",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["items"],
                "properties": {
                  "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" } },
                  "coupon_code": { "type": "string", "nullable": true },
                  "delivery_type": { "type": "string", "enum": ["delivery","pickup"], "default": "delivery" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order calculation",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/OrderCalculation" } } }] } } } }
        }
      }
    },
    "/orders": {
      "post": {
        "tags": ["Orders"],
        "summary": "Place a new order",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["items", "location_id"],
                "properties": {
                  "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" }, "minItems": 1 },
                  "location_id": { "type": "integer" },
                  "delivery_type": { "type": "string", "enum": ["delivery","pickup"], "default": "delivery" },
                  "delivery_address": { "type": "string", "description": "Required if delivery_type is delivery" },
                  "delivery_latitude": { "type": "number", "nullable": true },
                  "delivery_longitude": { "type": "number", "nullable": true },
                  "coupon_code": { "type": "string", "nullable": true },
                  "special_instructions": { "type": "string", "nullable": true },
                  "payment_method": { "type": "string", "enum": ["cash_on_delivery","payu"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Order placed",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/SuccessResponse" }, { "type": "object", "properties": { "data": { "type": "object", "properties": { "order_id": { "type": "integer" }, "order_number": { "type": "string" }, "total_amount": { "type": "number" } } } } }] } } } },
          "400": { "description": "Validation error or invalid coupon" }
        }
      },
      "get": {
        "tags": ["Orders"],
        "summary": "Get my orders with pagination",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "in": "query", "name": "status", "schema": { "type": "string", "enum": ["pending","confirmed","preparing","out_for_delivery","delivered","cancelled"] } },
          { "in": "query", "name": "page", "schema": { "type": "integer", "default": 1 } },
          { "in": "query", "name": "limit", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": { "200": { "description": "Paginated orders" } }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order detail with items, status history, payment",
        "security": [{ "BearerAuth": [] }],
