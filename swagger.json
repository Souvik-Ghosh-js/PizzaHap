{
  "openapi": "3.0.0",
  "info": {
    "title": "PizzaHap API",
    "version": "2.0.0",
    "description": "Location-aware pizza ordering platform. Each branch has its own menu availability. Admin can toggle products per location."
  },
  "servers": [{ "url": "http://13.232.73.121/api", "description": "Production" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/locations": {
      "get": {
        "tags": ["Locations"],
        "summary": "Get all active locations, sorted by distance if lat/lng provided",
        "security": [],
        "parameters": [
          { "in": "query", "name": "latitude",  "schema": { "type": "number" } },
          { "in": "query", "name": "longitude", "schema": { "type": "number" } }
        ],
        "responses": { "200": { "description": "List of locations" } }
      }
    },
    "/locations/nearest": {
      "get": {
        "tags": ["Locations"],
        "summary": "Get nearest location to given coordinates",
        "security": [],
        "parameters": [
          { "in": "query", "name": "latitude",  "schema": { "type": "number" } },
          { "in": "query", "name": "longitude", "schema": { "type": "number" } }
        ],
        "responses": { "200": { "description": "Nearest location object" } }
      }
    },
    "/auth/send-otp": {
      "post": { "tags": ["Auth"], "summary": "Send OTP to email", "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" } } } } } },
        "responses": { "200": { "description": "OTP sent" } }
      }
    },
    "/auth/resend-otp": {
      "post": { "tags": ["Auth"], "summary": "Resend OTP", "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" } } } } } },
        "responses": { "200": { "description": "OTP resent" } }
      }
    },
    "/auth/register": {
      "post": { "tags": ["Auth"], "summary": "Register new user", "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" }, "email": { "type": "string" }, "otp": { "type": "string" }, "mobile": { "type": "string" } } } } } },
        "responses": { "201": { "description": "User registered, tokens returned" } }
      }
    },
    "/auth/login": {
      "post": { "tags": ["Auth"], "summary": "Login with OTP", "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" }, "otp": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Tokens returned" } }
      }
    },
    "/auth/me": {
      "get": { "tags": ["Auth"], "summary": "Get current user profile", "responses": { "200": { "description": "User object" } } }
    },
    "/auth/logout": {
      "post": { "tags": ["Auth"], "summary": "Logout", "responses": { "200": { "description": "Logged out" } } }
    },
    "/menu/categories": {
      "get": { "tags": ["Menu"], "summary": "List all active categories", "security": [], "responses": { "200": { "description": "Category list" } } }
    },
    "/menu/products": {
      "get": {
        "tags": ["Menu"],
        "summary": "List products, filtered by location if location_id provided",
        "security": [],
        "parameters": [
          { "in": "query", "name": "location_id", "schema": { "type": "integer" }, "description": "Filter out products unavailable at this location" },
          { "in": "query", "name": "category_id", "schema": { "type": "integer" } },
          { "in": "query", "name": "is_veg",      "schema": { "type": "boolean" } },
          { "in": "query", "name": "search",      "schema": { "type": "string"  } },
          { "in": "query", "name": "page",        "schema": { "type": "integer" } },
          { "in": "query", "name": "limit",       "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Paginated product list" } }
      }
    },
    "/menu/products/featured": {
      "get": {
        "tags": ["Menu"], "summary": "Featured products", "security": [],
        "parameters": [{ "in": "query", "name": "location_id", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Featured product list" } }
      }
    },
    "/menu/products/{id}": {
      "get": {
        "tags": ["Menu"], "summary": "Get single product with sizes, crusts, toppings", "security": [],
        "parameters": [
          { "in": "path",  "name": "id",          "required": true, "schema": { "type": "integer" } },
          { "in": "query", "name": "location_id", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Product detail" }, "404": { "description": "Not found or unavailable at location" } }
      }
    },
    "/menu/toppings": { "get": { "tags": ["Menu"], "summary": "List toppings", "security": [], "responses": { "200": { "description": "Toppings" } } } },
    "/menu/crusts":   { "get": { "tags": ["Menu"], "summary": "List crusts",   "security": [], "responses": { "200": { "description": "Crusts" } } } },
    "/orders": {
      "post": { "tags": ["Orders"], "summary": "Place order",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": { "201": { "description": "Order placed" } }
      },
      "get": { "tags": ["Orders"], "summary": "Get my orders",
        "parameters": [{ "in": "query", "name": "status", "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Orders list" } }
      }
    },
    "/orders/calculate": {
      "post": { "tags": ["Orders"], "summary": "Calculate order totals",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": { "200": { "description": "Calculated totals" } }
      }
    },
    "/orders/{id}": {
      "get": { "tags": ["Orders"], "summary": "Get order detail",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Order detail" } }
      }
    },
    "/orders/{id}/cancel": {
      "post": { "tags": ["Orders"], "summary": "Cancel order",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Cancelled" } }
      }
    },
    "/coupons": { "get": { "tags": ["Coupons"], "summary": "List active coupons", "responses": { "200": { "description": "Coupons" } } } },
    "/coupons/validate": {
      "post": { "tags": ["Coupons"], "summary": "Validate coupon code",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "code": { "type": "string" }, "order_value": { "type": "number" } } } } } },
        "responses": { "200": { "description": "Coupon details with calculated discount" } }
      }
    },
    "/notifications": { "get": { "tags": ["Notifications"], "summary": "Get my notifications", "responses": { "200": { "description": "Notifications" } } } },
    "/notifications/read-all": { "put": { "tags": ["Notifications"], "summary": "Mark all read", "responses": { "200": { "description": "Marked" } } } },
    "/support/tickets": {
      "get":  { "tags": ["Support"], "summary": "My tickets", "responses": { "200": { "description": "Tickets" } } },
      "post": { "tags": ["Support"], "summary": "Create ticket", "responses": { "201": { "description": "Created" } } }
    },
    "/refunds/request": { "post": { "tags": ["Refunds"], "summary": "Request refund", "responses": { "200": { "description": "Requested" } } } },
    "/refunds/my-refunds": { "get": { "tags": ["Refunds"], "summary": "My refunds", "responses": { "200": { "description": "Refunds" } } } },
    "/admin/auth/login": {
      "post": { "tags": ["Admin"], "summary": "Admin login — returns token + admin info with location_name",
        "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["email","password"],
          "properties": { "email": { "type": "string" }, "password": { "type": "string" }, "location_id": { "type": "integer", "description": "Optional for super_admin to scope to a branch" } } } } } },
        "responses": { "200": { "description": "token + admin object including location_id and location_name" } }
      }
    },
    "/admin/dashboard": { "get": { "tags": ["Admin"], "summary": "Dashboard KPIs (scoped to admin location if set)", "responses": { "200": { "description": "KPI data" } } } },
    "/admin/dashboard/reports": {
      "get": { "tags": ["Admin"], "summary": "Revenue reports",
        "parameters": [{ "in": "query", "name": "period", "schema": { "type": "string", "enum": ["daily","weekly","monthly"] } }],
        "responses": { "200": { "description": "Report rows" } }
      }
    },
    "/admin/orders": {
      "get": { "tags": ["Admin"], "summary": "List all orders (auto-filtered by admin location)",
        "parameters": [
          { "in": "query", "name": "status",      "schema": { "type": "string" } },
          { "in": "query", "name": "location_id", "schema": { "type": "integer" }, "description": "Only used by super_admin (others use their own location)" }
        ],
        "responses": { "200": { "description": "Paginated orders" } }
      }
    },
    "/admin/orders/{id}/status": {
      "put": { "tags": ["Admin"], "summary": "Update order status",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" }, "note": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/admin/menu/products": {
      "get": { "tags": ["Admin Menu"], "summary": "Get ALL products including unavailable (admin only). Returns location_available when admin is location-scoped.",
        "parameters": [
          { "in": "query", "name": "show_unavailable", "schema": { "type": "boolean" }, "description": "true = include globally disabled products" },
          { "in": "query", "name": "search",           "schema": { "type": "string" } },
          { "in": "query", "name": "category_id",      "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Products with location_available field" } }
      },
      "post": { "tags": ["Admin Menu"], "summary": "Create product",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["name","base_price","category_id"],
          "properties": { "name": { "type": "string" }, "base_price": { "type": "number" }, "category_id": { "type": "integer" }, "is_veg": { "type": "boolean" }, "is_featured": { "type": "boolean" }, "description": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Created with product_id" } }
      }
    },
    "/admin/menu/products/{id}": {
      "put": { "tags": ["Admin Menu"], "summary": "Update product globally",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": { "tags": ["Admin Menu"], "summary": "Soft-delete product (hides from all menus)",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Removed" } }
      }
    },
    "/admin/menu/products/{id}/image": {
      "post": { "tags": ["Admin Menu"], "summary": "Upload product image",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "image": { "type": "string", "format": "binary" } } } } } },
        "responses": { "200": { "description": "image_url returned" } }
      }
    },
    "/admin/menu/products/{id}/location-availability": {
      "put": { "tags": ["Admin Menu"],
        "summary": "Toggle product on/off at a location. Location-scoped admin uses their own location. Super-admin must pass location_id in body.",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["is_available"],
          "properties": { "is_available": { "type": "boolean" }, "location_id": { "type": "integer", "description": "Required for super_admin only" } } } } } },
        "responses": { "200": { "description": "Availability updated" } }
      }
    },
    "/admin/menu/products/{id}/availability-matrix": {
      "get": { "tags": ["Admin Menu"],
        "summary": "Get availability status for this product across ALL locations (super_admin view)",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Array of {location_id, location_name, is_available}" } }
      }
    },
    "/admin/users": { "get": { "tags": ["Admin"], "summary": "List users", "responses": { "200": { "description": "Users" } } } },
    "/admin/users/{id}/block": {
      "put": { "tags": ["Admin"], "summary": "Block / unblock user",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "is_blocked": { "type": "boolean" } } } } } },
        "responses": { "200": { "description": "Done" } }
      }
    },
    "/admin/coupons": {
      "post": { "tags": ["Admin"], "summary": "Create coupon",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/admin/refunds": { "get": { "tags": ["Admin"], "summary": "All refunds", "responses": { "200": { "description": "Refunds" } } } },
    "/admin/refunds/{id}/process": {
      "post": { "tags": ["Admin"], "summary": "Process refund",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Processed" } }
      }
    },
    "/admin/support/tickets": { "get": { "tags": ["Admin"], "summary": "All support tickets", "responses": { "200": { "description": "Tickets" } } } },
    "/admin/support/tickets/{id}/reply": {
      "post": { "tags": ["Admin"], "summary": "Reply to ticket",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Replied" } }
      }
    }
  }
}
